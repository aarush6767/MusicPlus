{
  "manifest_version": 3,
  "name": "MusicPlus",
  "version": "1.0.0",
  "description": "Supercharge your Apple Music web player with sleep timer, mini player, keyboard shortcuts, and now-playing notifications.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://music.apple.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://music.apple.com/*"
      ],
      "js": [
        "content.js",
        "mini-player.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "mini-player.css",
        "popup.css"
      ],
      "matches": [
        "*://music.apple.com/*"
      ]
    }
  ]
}